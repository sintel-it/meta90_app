FLASK_SECRET_KEY=REEMPLAZA_CON_UNA_CLAVE_LARGA_Y_UNICA
DB_PATH=metas.db
BACKUP_DIR=backups
BACKUP_KEEP_DAYS=14
BACKUP_OFFSITE_DIR=
SESSION_DAYS=30
REMEMBER_ME_DAYS=90
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax

# Facebook Login (OAuth)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_SCOPE=email,public_profile
FACEBOOK_GRAPH_VERSION=v21.0

# Google Login (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SCOPE=openid email profile
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Microsoft Login (OAuth)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_SCOPE=openid profile email User.Read

# Web Push (navegador)
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@meta.local

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_DEFAULT_COUNTRY_CODE=+1
ENABLE_TEST_NOTIFICATIONS=0
SMS_TEST_MIN_NOTIFICATIONS=0
FORCE_NOTIFICATIONS_TEST=0
NOTIFICATIONS_FORCE_EACH_RUN=0
ALERT_EMAIL_TO=
ALERT_WEBHOOK_URL=

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# template_then_text (recomendado en sandbox), template_only, text_only
WHATSAPP_NOTI_MODE=template_then_text
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANG=en_US

# Orden de envio:
# auto   => Resend -> SMTP
# resend => Resend -> SMTP
# smtp   => SMTP -> Resend
MAIL_PROVIDER=auto

# Proveedor recomendado (general): Resend API
RESEND_API_KEY=
RESEND_FROM=Meta90 <onboarding@resend.dev>

# Fallback opcional: SMTP clasico
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=TU_APP_PASSWORD
SMTP_FROM=tu_correo@gmail.com
SMTP_USE_TLS=1
